@model DishCatalogViewModel

@{
    ViewData["Title"] = "Каталог блюд";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="mb-0">Каталог блюд</h1>
    <a asp-controller="Dishes" asp-action="Create" class="btn btn-primary">Добавить рецепт</a>
</div>

<form asp-controller="Dishes" asp-action="Index" method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <label for="searchQuery" class="form-label">Поиск</label>
        <input id="searchQuery" name="searchQuery" type="search" class="form-control" value="@Model.SearchQuery" placeholder="Название, ингредиент или состав" />
    </div>

    <div class="col-md-4">
        <label for="categoryId" class="form-label">Категория</label>
        <select id="categoryId" name="categoryId" class="form-select">
            <option value="">Все категории</option>
            @foreach (var category in Model.Categories)
            {
                <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">
                    @category.Name
                </option>
            }
        </select>
    </div>

    <div class="col-md-4">
        <label for="mainIngredient" class="form-label">Основной ингредиент</label>
        <select id="mainIngredient" name="mainIngredient" class="form-select">
            <option value="">Любой ингредиент</option>
            @foreach (var ingredient in Model.MainIngredients)
            {
                <option value="@ingredient" selected="@(Model.MainIngredient == ingredient)">
                    @ingredient
                </option>
            }
        </select>
    </div>

    <div class="col-md-4">
        <label for="maxCookingTime" class="form-label">Время до, мин.</label>
        <input id="maxCookingTime" name="maxCookingTime" type="number" min="1" class="form-control" value="@Model.MaxCookingTime" />
    </div>

    <div class="col-md-4">
        <label for="isForChildren" class="form-label">Для детей</label>
        <select id="isForChildren" name="isForChildren" class="form-select">
            <option value="">Любой вариант</option>
            <option value="true" selected="@(Model.IsForChildren == true)">Да</option>
            <option value="false" selected="@(Model.IsForChildren == false)">Нет</option>
        </select>
    </div>

    <div class="col-md-4">
        <label for="dietTypeId" class="form-label">Тип питания</label>
        <select id="dietTypeId" name="dietTypeId" class="form-select">
            <option value="">Любой тип питания</option>
            @foreach (var dietType in Model.DietTypes)
            {
                <option value="@dietType.Id" selected="@(Model.DietTypeId == dietType.Id)">
                    @dietType.Name
                </option>
            }
        </select>
    </div>

    <div class="col-md-4">
        <label for="allergenId" class="form-label">Аллерген</label>
        <select id="allergenId" name="allergenId" class="form-select">
            <option value="">Любой аллерген</option>
            @foreach (var allergen in Model.Allergens)
            {
                <option value="@allergen.Id" selected="@(Model.AllergenId == allergen.Id)">
                    @allergen.Name
                </option>
            }
        </select>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Показать</button>
        <a asp-controller="Dishes" asp-action="Index" class="btn btn-outline-secondary">Сбросить фильтры</a>
    </div>
</form>

@if (!Model.Dishes.Any())
{
    <div class="alert alert-info">
        По выбранным условиям блюда не найдены.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Категория</th>
                    <th>Ккал</th>
                    <th>Белки</th>
                    <th>Жиры</th>
                    <th>Углеводы</th>
                    <th>Время</th>
                    <th>Ингредиент</th>
                    <th>Для детей</th>
                    <th>Типы питания</th>
                    <th>Аллергены</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dish in Model.Dishes)
                {
                    <tr>
                        <td>
                            <div>@dish.Name</div>
                            @if (dish.HasAllergyWarning)
                            {
                                <div class="alert alert-warning py-1 px-2 mt-2 mb-0 small">
                                    Содержит ваши аллергены: @string.Join(", ", dish.MatchingUserAllergenNames)
                                </div>
                            }
                        </td>
                        <td>@dish.CategoryName</td>
                        <td>@dish.Calories.ToString("0")</td>
                        <td>@dish.Proteins.ToString("0")</td>
                        <td>@dish.Fats.ToString("0")</td>
                        <td>@dish.Carbs.ToString("0")</td>
                        <td>@dish.CookingTime мин.</td>
                        <td>@(dish.MainIngredient ?? "Не указан")</td>
                        <td>@(dish.IsForChildren ? "Да" : "Нет")</td>
                        <td>@(dish.DietTypeNames.Any() ? string.Join(", ", dish.DietTypeNames) : "Не указано")</td>
                        <td>@(dish.AllergenNames.Any() ? string.Join(", ", dish.AllergenNames) : "Не указано")</td>
                        <td>
                            <a asp-controller="Dishes" asp-action="Details" asp-route-id="@dish.Id" class="btn btn-sm btn-outline-primary">
                                Подробнее
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
