<!DOCTYPE html>
@{
    var currentController = Convert.ToString(ViewContext.RouteData.Values["controller"]);
    var currentAction = Convert.ToString(ViewContext.RouteData.Values["action"]);

    string NavClass(string controller, string action = "")
    {
        var isActive = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            && (string.IsNullOrEmpty(action) || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));

        return isActive ? "nav-link sm-nav-link active" : "nav-link sm-nav-link";
    }
}

<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartMeal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartMeal.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light sm-navbar">
            <div class="container-fluid">
                <a class="navbar-brand sm-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <svg class="sm-brand__leaf" viewBox="0 0 24 24" role="img" aria-label="Лист">
                        <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M5.1 18.7 2.9 21" />
                        <path fill="currentColor" d="M3.8 13.9C4.7 7 10.4 3 20.2 3.1c.6 0 1 .5 1 1-.4 8.2-4.9 14.4-11.6 15.1-4.1.4-6.4-1.9-5.8-5.3Z" />
                        <path fill="none" stroke="#fff" stroke-linecap="round" stroke-width="1.8" d="M7.2 16.1c3.1-4.4 7.1-6.9 11.5-7.8" />
                    </svg>
                    <span>SmartMeal</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="@NavClass("Home", "Index")" asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Dishes")" asp-area="" asp-controller="Dishes" asp-action="Index">Каталог блюд</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("MyRecipes")" asp-area="" asp-controller="MyRecipes" asp-action="Index">Мои рецепты</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Favorites")" asp-area="" asp-controller="Favorites" asp-action="Index">Избранное</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("MealPlans")" asp-area="" asp-controller="MealPlans" asp-action="Index">План питания</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("WeeklyReports")" asp-area="" asp-controller="WeeklyReports" asp-action="Index">Отчёты</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("UserProfiles")" asp-area="" asp-controller="UserProfiles" asp-action="Index">Профиль</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Home", "Privacy")" asp-area="" asp-controller="Home" asp-action="Privacy">О проекте</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="sm-main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container">
            &copy; 2026 - SmartMeal - <a asp-area="" asp-controller="Home" asp-action="Privacy">О проекте</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
