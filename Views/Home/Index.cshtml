@model HomeDashboardViewModel

@{
    ViewData["Title"] = "Главная";
}

<div class="sm-page-header">
    <p class="text-muted mb-1">@Model.CurrentDayName, неделя @Model.CurrentWeekNumber</p>
    <h1 class="mb-2">Здравствуйте, @Model.DemoUserDisplayName!</h1>
    <p class="text-muted mb-0">Сегодняшний план питания и краткая сводка по калориям.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="sm-stat-card">
            <div class="text-muted small">Цель на день</div>
            <div class="fs-3 fw-semibold">@Model.DailyCalorieTarget.ToString("0")</div>
            <div class="text-muted small">ккал</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="sm-stat-card">
            <div class="text-muted small">Запланировано</div>
            <div class="fs-3 fw-semibold">@Model.TodayActualCalories.ToString("0")</div>
            <div class="text-muted small">ккал</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="sm-stat-card">
            <div class="text-muted small">Статус</div>
            <div class="fs-4 fw-semibold">
                <span class="@GetStatusClass(Model.CalorieStatusText)">@Model.CalorieStatusText</span>
            </div>
            <div class="text-muted small">по дневной норме</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="sm-stat-card">
            <div class="text-muted small">Приемы пищи</div>
            <div class="fs-3 fw-semibold">@Model.PlannedMealsCount / @Model.PlannedMeals.Count</div>
            <div class="text-muted small">выбрано на сегодня</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <h2 class="h4 mb-0">План на сегодня</h2>
            <a asp-controller="MealPlans" asp-action="Index" class="btn btn-outline-primary btn-sm">Открыть план питания</a>
        </div>

        <div class="table-responsive sm-table-wrap">
            <table class="table table-bordered align-middle sm-table">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Прием пищи</th>
                        <th scope="col">Блюдо</th>
                        <th scope="col">Ккал</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var meal in Model.PlannedMeals)
                    {
                        <tr>
                            <th scope="row">@meal.MealType</th>
                            <td>
                                @if (meal.IsSelected)
                                {
                                    <div>@meal.DishName</div>

                                    @if (meal.HasAllergyWarning)
                                    {
                                        <div class="alert alert-warning py-1 px-2 mt-2 mb-0 small">
                                            Содержит ваши аллергены: @string.Join(", ", meal.MatchingAllergenNames)
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Не выбрано</span>
                                }
                            </td>
                            <td>@(meal.IsSelected ? meal.Calories.ToString("0") : "0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sm-panel h-100">
        <h2 class="h4 mb-3">Быстрые действия</h2>
        <div class="d-grid gap-2 mb-4">
            <a asp-controller="MealPlans" asp-action="Index" class="btn btn-primary">План питания</a>
            <a asp-controller="WeeklyReports" asp-action="Index" class="btn btn-outline-primary">Недельный отчёт</a>
            <a asp-controller="Dishes" asp-action="Index" class="btn btn-outline-primary">Каталог блюд</a>
            <a asp-controller="MyRecipes" asp-action="Index" class="btn btn-outline-primary">Мои рецепты</a>
            <a asp-controller="UserProfiles" asp-action="Index" class="btn btn-outline-primary">Профиль</a>
            <a asp-controller="Dishes" asp-action="Create" class="btn btn-outline-success">Добавить рецепт</a>
        </div>

        <h2 class="h4 mb-3">Аллергены</h2>
        @if (Model.HasAllergyWarnings)
        {
            <div class="list-group">
                @foreach (var warning in Model.AllergyWarnings)
                {
                    <div class="list-group-item">
                        <div class="fw-semibold">@warning.MealType: @warning.DishName</div>
                        <div class="small text-warning-emphasis">
                            Содержит ваши аллергены: @string.Join(", ", warning.AllergenNames)
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-success mb-0">
                В выбранных на сегодня блюдах ваши аллергены не найдены.
            </div>
        }
        </div>
    </div>
</div>

@functions {
    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "В норме" => "badge bg-success",
            "Превышение" => "badge bg-danger",
            _ => "badge bg-warning text-dark"
        };
    }
}
