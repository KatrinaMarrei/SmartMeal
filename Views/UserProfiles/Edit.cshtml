@model UserProfileViewModel

@{
    ViewData["Title"] = "Редактировать профиль";
}

<div class="sm-page-header">
    <h1 class="mb-0">Редактировать профиль</h1>
</div>

<form asp-controller="UserProfiles" asp-action="Edit" method="post" class="row g-3 sm-panel">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-8">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Gender" class="form-label"></label>
        <select asp-for="Gender" asp-items="Model.GenderOptions" class="form-select">
            <option value="">Выберите пол</option>
        </select>
        <span asp-validation-for="Gender" class="text-danger"></span>
    </div>

    <div class="col-md-2">
        <label asp-for="Age" class="form-label"></label>
        <input asp-for="Age" class="form-control" type="number" min="1" max="120" />
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Weight" class="form-label"></label>
        <input asp-for="Weight" class="form-control" type="number" min="1" max="300" step="0.01" />
        <span asp-validation-for="Weight" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Height" class="form-label"></label>
        <input asp-for="Height" class="form-control" type="number" min="1" max="250" step="0.01" />
        <span asp-validation-for="Height" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Goal" class="form-label"></label>
        <select asp-for="Goal" asp-items="Model.GoalOptions" class="form-select">
            <option value="">Выберите цель</option>
        </select>
        <span asp-validation-for="Goal" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="ActivityLevel" class="form-label"></label>
        <select asp-for="ActivityLevel" asp-items="Model.ActivityLevelOptions" class="form-select">
            <option value="">Выберите уровень</option>
        </select>
        <span asp-validation-for="ActivityLevel" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <div class="form-label">Текущая расчётная норма калорий</div>
        <div class="form-control-plaintext">@Model.DailyCalories.ToString("0") ккал</div>
        <div class="form-text">Норма калорий рассчитывается автоматически после сохранения профиля.</div>
    </div>

    <div class="col-12">
        <fieldset>
            <legend class="h5">Аллергены</legend>
            <span asp-validation-for="SelectedAllergenIds" class="text-danger"></span>
            @foreach (var allergen in Model.Allergens)
            {
                <div class="form-check d-flex align-items-center gap-2 mb-1">
                    <input class="form-check-input"
                           type="checkbox"
                           name="SelectedAllergenIds"
                           id="allergen_@allergen.Id"
                           value="@allergen.Id"
                           checked="@Model.SelectedAllergenIds.Contains(allergen.Id)" />
                    <label class="form-check-label mb-0" for="allergen_@allergen.Id">@allergen.Name</label>
                </div>
            }
        </fieldset>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-controller="UserProfiles" asp-action="Index" class="btn btn-outline-secondary">Назад к профилю</a>
    </div>
</form>
