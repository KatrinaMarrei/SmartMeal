@model UserProfileViewModel

@{
    ViewData["Title"] = "Редактировать профиль";
}

<h1 class="mb-4">Редактировать профиль</h1>

<form asp-controller="UserProfiles" asp-action="Edit" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-8">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Gender" class="form-label"></label>
        <input asp-for="Gender" class="form-control" />
        <span asp-validation-for="Gender" class="text-danger"></span>
    </div>

    <div class="col-md-2">
        <label asp-for="Age" class="form-label"></label>
        <input asp-for="Age" class="form-control" type="number" min="1" max="120" />
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Weight" class="form-label"></label>
        <input asp-for="Weight" class="form-control" type="number" min="1" max="300" step="0.01" />
        <span asp-validation-for="Weight" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Height" class="form-label"></label>
        <input asp-for="Height" class="form-control" type="number" min="1" max="250" step="0.01" />
        <span asp-validation-for="Height" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Goal" class="form-label"></label>
        <input asp-for="Goal" class="form-control" />
        <span asp-validation-for="Goal" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="ActivityLevel" class="form-label"></label>
        <input asp-for="ActivityLevel" class="form-control" type="number" min="1" max="5" />
        <span asp-validation-for="ActivityLevel" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="DailyCalories" class="form-label"></label>
        <input asp-for="DailyCalories" class="form-control" type="number" min="0" max="10000" step="0.01" />
        <span asp-validation-for="DailyCalories" class="text-danger"></span>
    </div>

    <div class="col-12">
        <fieldset>
            <legend class="h5">Аллергены</legend>
            <span asp-validation-for="SelectedAllergenIds" class="text-danger"></span>
            @foreach (var allergen in Model.Allergens)
            {
                <div class="form-check d-flex align-items-center gap-2 mb-1">
                    <input class="form-check-input"
                           type="checkbox"
                           name="SelectedAllergenIds"
                           id="allergen_@allergen.Id"
                           value="@allergen.Id"
                           checked="@Model.SelectedAllergenIds.Contains(allergen.Id)" />
                    <label class="form-check-label mb-0" for="allergen_@allergen.Id">@allergen.Name</label>
                </div>
            }
        </fieldset>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-controller="UserProfiles" asp-action="Index" class="btn btn-outline-secondary">Назад к профилю</a>
    </div>
</form>
